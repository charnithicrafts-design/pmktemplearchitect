# =========================================================
#  P.M.K. Temple Architect — Apache Rewrite Rules
#  Required for Nuxt static hosting on shared Apache servers
# =========================================================

Options -MultiViews
DirectoryIndex index.html

# ── Correct MIME types (critical for JS modules) ──────────────
<IfModule mod_mime.c>
  AddType application/javascript   .js .mjs
  AddType text/css                 .css
  AddType application/json         .json
  AddType image/jpeg               .jpg .jpeg
  AddType image/png                .png
  AddType image/webp               .webp
  AddType image/svg+xml            .svg
  AddType font/woff2               .woff2
  AddType font/woff                .woff
</IfModule>

# ── SPA Routing ───────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Serve existing files and directories directly (JS, CSS, images…)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. Clean URLs: /about → /about/index.html
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*[^/])/?$ /$1/index.html [L]

  # 3. Final fallback → Nuxt SPA shell
  RewriteRule ^ /200.html [L]
</IfModule>

# ── Compression ───────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Cache control ─────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Hashed assets — cache forever
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css               "access plus 1 year"
  # Images — 1 month
  ExpiresByType image/jpeg             "access plus 1 month"
  ExpiresByType image/png              "access plus 1 month"
  ExpiresByType image/webp             "access plus 1 month"
  # HTML — no cache (so updates show immediately)
  ExpiresByType text/html              "access plus 0 seconds"
</IfModule>
